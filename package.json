{
  "name": "@figma/my-make-file",
  "private": true,
  "version": "0.0.1",
  "description": "Lumina Worship desktop presentation system",
  "main": "electron/main.cjs",
  "type": "module",
  "engines": {
    "node": ">=22.5.0"
  },
  "scripts": {
    "build": "vite build",
    "desktop:build": "npm run backend:build && npm run build",
    "desktop:dist:win": "npm run desktop:build && electron-builder --win nsis --x64",
    "dev": "vite",
    "backend:dev": "TS_NODE_PROJECT=tsconfig.backend.json node -r ts-node/register server/src/main.ts",
    "backend:build": "tsc -p tsconfig.backend.json && node server/scripts/write-dist-package.cjs",
    "backend:start": "node server/dist/main.js",
    "backend:test": "TS_NODE_PROJECT=tsconfig.backend.json node -r ts-node/register server/test/backend.spec.ts",
    "scripture:seed": "TS_NODE_PROJECT=tsconfig.backend.json node -r ts-node/register server/scripts/seed-scriptures.ts",
    "scripture:seed:popular": "SCRIPTURE_TRANSLATIONS=MSG,AMP,AMPC,NLT,NIV,ESV,NKJV,NASB,CSB,HCSB,KJV TS_NODE_PROJECT=tsconfig.backend.json node -r ts-node/register server/scripts/seed-scriptures.ts",
    "scripture:seed:all": "SCRIPTURE_TRANSLATIONS=MSG,AMP,AMPC,NLT,NIV,ESV,NKJV,NASB,CSB,HCSB,KJV,MEV,LSB,NRSV,RSV,CEV,NCV,NIRV,GNT,TLB,ISV,PHILLIPS TS_NODE_PROJECT=tsconfig.backend.json node -r ts-node/register server/scripts/seed-scriptures.ts"
  },
  "dependencies": {
    "@emotion/react": "11.14.0",
    "@emotion/styled": "11.14.1",
    "@mui/icons-material": "7.3.5",
    "@mui/material": "7.3.5",
    "@nestjs/common": "^11.1.21",
    "@nestjs/core": "^11.1.21",
    "@nestjs/event-emitter": "^3.1.0",
    "@nestjs/platform-express": "^11.1.21",
    "@nestjs/platform-socket.io": "^11.1.21",
    "@nestjs/websockets": "^11.1.21",
    "@popperjs/core": "2.11.8",
    "@radix-ui/react-accordion": "1.2.3",
    "@radix-ui/react-alert-dialog": "1.1.6",
    "@radix-ui/react-aspect-ratio": "1.1.2",
    "@radix-ui/react-avatar": "1.1.3",
    "@radix-ui/react-checkbox": "1.1.4",
    "@radix-ui/react-collapsible": "1.1.3",
    "@radix-ui/react-context-menu": "2.2.6",
    "@radix-ui/react-dialog": "1.1.6",
    "@radix-ui/react-dropdown-menu": "2.1.6",
    "@radix-ui/react-hover-card": "1.1.6",
    "@radix-ui/react-label": "2.1.2",
    "@radix-ui/react-menubar": "1.1.6",
    "@radix-ui/react-navigation-menu": "1.2.5",
    "@radix-ui/react-popover": "1.1.6",
    "@radix-ui/react-progress": "1.1.2",
    "@radix-ui/react-radio-group": "1.2.3",
    "@radix-ui/react-scroll-area": "1.2.3",
    "@radix-ui/react-select": "2.1.6",
    "@radix-ui/react-separator": "1.1.2",
    "@radix-ui/react-slider": "1.2.3",
    "@radix-ui/react-slot": "1.1.2",
    "@radix-ui/react-switch": "1.1.3",
    "@radix-ui/react-tabs": "1.1.3",
    "@radix-ui/react-toggle": "1.1.2",
    "@radix-ui/react-toggle-group": "1.1.2",
    "@radix-ui/react-tooltip": "1.1.8",
    "canvas-confetti": "1.9.4",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.15.1",
    "class-variance-authority": "0.7.1",
    "clsx": "2.1.1",
    "cmdk": "1.1.1",
    "date-fns": "3.6.0",
    "embla-carousel-react": "8.6.0",
    "input-otp": "1.4.2",
    "lucide-react": "0.487.0",
    "motion": "12.23.24",
    "next-themes": "0.4.6",
    "react-day-picker": "8.10.1",
    "react-dnd": "16.0.1",
    "react-dnd-html5-backend": "16.0.1",
    "react-hook-form": "7.55.0",
    "react-popper": "2.3.0",
    "react-resizable-panels": "2.1.7",
    "react-responsive-masonry": "2.7.1",
    "react-router": "7.13.0",
    "react-slick": "0.31.0",
    "recharts": "2.15.2",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2",
    "socket.io": "^4.8.3",
    "socket.io-client": "^4.8.3",
    "sonner": "2.0.3",
    "tailwind-merge": "3.2.0",
    "tw-animate-css": "1.3.8",
    "vaul": "1.1.2"
  },
  "devDependencies": {
    "@tailwindcss/vite": "4.1.12",
    "@types/node": "^25.8.0",
    "@vitejs/plugin-react": "4.7.0",
    "electron": "^42.2.0",
    "electron-builder": "^26.8.1",
    "tailwindcss": "4.1.12",
    "ts-node": "^10.9.2",
    "tsx": "^4.22.0",
    "typescript": "^6.0.3",
    "vite": "6.3.5"
  },
  "peerDependencies": {
    "react": "18.3.1",
    "react-dom": "18.3.1"
  },
  "peerDependenciesMeta": {
    "react": {
      "optional": true
    },
    "react-dom": {
      "optional": true
    }
  },
  "pnpm": {
    "overrides": {
      "vite": "6.3.5"
    }
  },
  "build": {
    "appId": "com.lumina.worship",
    "productName": "Lumina Worship",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "electron/**/*",
      "server/dist/**/*",
      "package.json"
    ],
    "win": {
      "artifactName": "${productName} Setup ${version}.${ext}",
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "nsis": {
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "oneClick": false
    }
  }
}
